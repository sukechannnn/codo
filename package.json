{
  "name": "codo",
  "version": "0.1.0",
  "description": "Task queue manager for Claude Code - CLI, TUI, and CC skill",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sukechannnn/codo.git"
  },
  "keywords": [
    "claude-code",
    "task-queue",
    "tui",
    "cli"
  ],
  "bin": {
    "codo": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "scripts"
