    "proper-lockfile": "^4.1.2",
    "react": "^18.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^18.3.28",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
